# ─────────────────────────────────────────────────────────────────────────────
# SafeShot AI — Environment Variables Example
# Copy this file to .env and customise
# ─────────────────────────────────────────────────────────────────────────────

# API key for backend authentication (leave empty to disable auth)
SAFESHOT_API_KEY=

# Comma-separated list of allowed CORS origins (* = allow all)
# For production, restrict to your extension's origin:
#   chrome-extension://YOUR_EXTENSION_ID
SAFESHOT_ALLOWED_ORIGINS=*

# Ollama base URL (only needed if using LLM engine)
OLLAMA_BASE_URL=http://localhost:11434
